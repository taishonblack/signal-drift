{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "mako-mcp",
      "version": "0.1.0",
      "title": "MAKO Broadcast MCP"
    },
    "tools": [
      {
        "name": "get_focused_input",
        "title": "Get session focus",
        "description": "Return the currently focused SRT input for a MAKO session, showing which stream operators are watching in 1-up mode.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "minLength": 1,
              "description": "The MAKO session ID."
            }
          },
          "required": [
            "session_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_recent_feedback",
        "title": "List recent feedback",
        "description": "Return the most recent user-submitted feedback entries for the MAKO app (newest first).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "Max entries to return (1-50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "submit_feedback",
        "title": "Submit feedback",
        "description": "Submit a feedback entry to the MAKO app on behalf of a user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "first_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "last_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "message": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            },
            "page_url": {
              "type": "string",
              "format": "uri",
              "description": "Optional page URL the feedback relates to."
            }
          },
          "required": [
            "first_name",
            "last_name",
            "email",
            "message"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
